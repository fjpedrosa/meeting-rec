# Runtime data: recordings, audio clips, SQLite databases, transcripts, etc.
# Keep only empty placeholder files so fresh clones have the expected folders.
data/**
!data/
!data/.gitkeep
!data/db/
!data/db/.gitkeep
!data/clips/
!data/clips/.gitkeep
!data/recordings/
!data/recordings/.gitkeep
